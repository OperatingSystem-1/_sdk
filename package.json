{
  "name": "@mitosislabs/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for managing OS-1 offices, agents, and integrations",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "os1": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": ["os1", "sdk", "offices", "agents", "integrations"],
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
